<div class="p-6">
  <% if notice %>
  <p class="mb-4 p-4 bg-green-100 text-green-700 rounded"><%= notice %></p>
  <% end %>

  <div class="mb-6">
    <%= link_to "← Back to unities", formation_module_unities_path(@unity.formation_module), class: "text-blue-600 hover:text-blue-800" %>
  </div>

  <div class="bg-white shadow-md rounded-lg p-6">
    <div class="flex justify-between items-start mb-6">
      <h1 class="text-3xl font-bold text-gray-900"><%= @unity.name %></h1>
      <% if current_person.is_a?(Dean) %>
      <div class="flex gap-2">
        <%= link_to "Edit", @formation_module ? edit_formation_module_unity_path(@formation_module, @unity) : edit_unity_path(@unity), class: "px-4 py-2 bg-yellow-600 text-white rounded hover:bg-yellow-700" %>
        <%= link_to "Destroy", @formation_module ? formation_module_unity_path(@formation_module, @unity) : @unity, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700" %>
      </div>
      <% end %>
    </div>

    <div class="mt-6">
      <h2 class="text-xl font-semibold mb-4">Module</h2>
      <p class="text-gray-900">
        <%= link_to @unity.formation_module.name, @unity.formation_module, class: "text-blue-600 hover:text-blue-800" %>
      </p>
    </div>
  </div>
</div>
