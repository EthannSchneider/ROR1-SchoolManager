<div class="p-6">
  <% if notice %>
  <p class="mb-4 p-4 bg-green-100 text-green-700 rounded"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-3xl font-bold">Modules</h1>
      <% if @formation_plan %>
      <p class="text-gray-600 mt-1">Formation Plan: <%= @formation_plan.name %></p>
      <% end %>
    </div>
    <% if current_person.is_a?(Dean) %>
    <% if @formation_plan %>
    <%= link_to "New module", new_formation_plan_formation_module_path(@formation_plan), class: "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700" %>
    <% end %>
    <% end %>
  </div>

  <div class="overflow-x-auto shadow-md rounded-lg">
    <table class="w-full border-collapse">
      <thead class="bg-gray-100 border-b">
        <tr>
          <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Name</th>
          <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Unities</th>
          <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Formation Plans</th>
          <th class="px-6 py-3 text-center text-sm font-semibold text-gray-700">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @formation_modules.each do |formation_module| %>
        <tr class="border-b hover:bg-gray-50">
          <td class="px-6 py-4 text-sm text-gray-900"><%= formation_module.name %></td>
          <td class="px-6 py-4 text-sm text-gray-900"><%= formation_module.unities.count %></td>
          <td class="px-6 py-4 text-sm text-gray-900"><%= formation_module.formation_plans.map(&:name).join(", ") %></td>
          <td class="px-6 py-4 text-center text-sm space-x-2">
            <%= link_to "Show", formation_module, class: "text-blue-600 hover:text-blue-800" %>
            <% if current_person.is_a?(Dean) %>
            <%= link_to "Edit", edit_formation_module_path(formation_module), class: "text-yellow-600 hover:text-yellow-800" %>
            <%= link_to "Destroy", formation_module, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-red-600 hover:text-red-800" %>
            <% end %>
          </td>
        </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <div class="mt-4">
    <%= render "shared/pagination_footer", records: @formation_modules, per_page: @pagination_per_page %>
  </div>
</div>