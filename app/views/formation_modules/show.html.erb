<div class="p-6">
  <% if notice %>
  <p class="mb-4 p-4 bg-green-100 text-green-700 rounded"><%= notice %></p>
  <% end %>

  <div class="mb-6">
    <% if @formation_plan %>
    <%= link_to "← Back to formation plan", formation_plan_path(@formation_plan), class: "text-blue-600 hover:text-blue-800" %>
    <% else %>
    <%= link_to "← Back to modules", formation_modules_path, class: "text-blue-600 hover:text-blue-800" %>
    <% end %>
  </div>

  <div class="bg-white shadow-md rounded-lg p-6">
    <div class="flex justify-between items-start mb-6">
      <h1 class="text-3xl font-bold text-gray-900"><%= @formation_module.name %></h1>
      <% if current_person.is_a?(Dean) %>
      <div class="flex gap-2">
        <%= link_to "Edit", edit_formation_plan_formation_module_path(@formation_plan, @formation_module), class: "px-4 py-2 bg-yellow-600 text-white rounded hover:bg-yellow-700" %>
        <%= link_to "Destroy", formation_plan_formation_module_path(@formation_plan, @formation_module), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700" %>
      </div>
      <% end %>
    </div>

    <div class="mt-6">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-xl font-semibold">Unities</h2>
        <% if current_person.is_a?(Dean) %>
        <%= link_to "Add Unity", new_formation_plan_formation_module_unity_path(@formation_plan, @formation_module), class: "px-3 py-1.5 bg-blue-600 text-white text-sm rounded hover:bg-blue-700" %>
        <% end %>
      </div>
      <% if @formation_module.unities.any? %>
      <ul class="space-y-2">
        <% @formation_module.unities.each do |unity| %>
        <li class="p-3 bg-gray-50 rounded">
          <%= link_to unity.name, formation_plan_formation_module_unity_path(@formation_plan, @formation_module, unity), class: "text-blue-600 hover:text-blue-800" %>
        </li>
        <% end %>
      </ul>
      <% else %>
      <p class="text-gray-500">No unities associated with this module.</p>
      <% end %>
    </div>

    <div class="mt-6">
      <h2 class="text-xl font-semibold mb-4">Formation Plans</h2>
      <% if @formation_module.formation_plans.any? %>
      <ul class="space-y-2">
        <% @formation_module.formation_plans.each do |plan| %>
        <li class="p-3 bg-gray-50 rounded">
          <%= link_to plan.name, formation_plan_path(plan), class: "text-blue-600 hover:text-blue-800" %>
        </li>
        <% end %>
      </ul>
      <% else %>
      <p class="text-gray-500">No formation plans associated with this module.</p>
      <% end %>
    </div>
  </div>
</div>