<div class="mx-auto max-w-7xl p-6">
  <div class="mb-6 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <div>
      <h1 class="text-3xl font-bold text-slate-900"><%= @title %></h1>
      <p class="mt-1 text-sm text-slate-500">
        Week <%= @calendar_start.cweek %>, <%= @calendar_start.cwyear %>
      </p>
    </div>

    <div class="flex flex-wrap gap-3">
      <%= link_to "Previous week", request.path + "?" + @previous_week_params.to_query, class: "rounded-lg border border-slate-200 px-4 py-2 text-sm font-medium text-slate-700 hover:border-slate-400" %>
      <%= link_to "Current week", request.path + "?" + { week: Date.current.cweek, year: Date.current.cwyear }.to_query, class: "rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-2 text-sm font-medium text-emerald-700 hover:border-emerald-300" %>
      <%= link_to "Next week", request.path + "?" + @next_week_params.to_query, class: "rounded-lg border border-slate-200 px-4 py-2 text-sm font-medium text-slate-700 hover:border-slate-400" %>
      <%= link_to "Back", @back_path, class: "rounded-lg bg-slate-700 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800" %>
    </div>
  </div>

  <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
    <div class="grid grid-cols-1 gap-px bg-slate-200 md:grid-cols-7">
      <% @week_days.each do |day| %>
        <div class="bg-white">
          <div class="border-b border-slate-200 bg-slate-50 px-4 py-3">
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500"><%= day.strftime("%A") %></p>
            <p class="mt-1 text-sm font-medium text-slate-900"><%= day.strftime("%d.%m.%Y") %></p>
          </div>

          <div class="min-h-56 space-y-3 px-4 py-4">
            <% events = (@events_by_day[day] || []).sort_by { |event| [event[:start_time] || Time.zone.parse("00:00"), event[:id]] } %>
            <% if events.empty? %>
              <p class="rounded-xl border border-dashed border-slate-200 px-3 py-4 text-sm text-slate-400">No course scheduled</p>
            <% else %>
              <% events.each do |event| %>
                <div class="rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 shadow-sm">
                  <div class="space-y-1">
                    <p class="text-sm font-semibold leading-tight text-slate-900"><%= event[:title] %></p>
                    <p class="text-xs font-semibold uppercase tracking-wide text-emerald-700">
                      <%= event[:start_time]&.strftime("%H:%M") || "--:--" %>
                      -
                      <%= event[:end_time]&.strftime("%H:%M") || "--:--" %>
                    </p>
                  </div>

                  <div class="mt-3 space-y-1 text-xs text-slate-600">
                    <% if event[:room].present? %>
                      <p>Room: <%= event[:room] %></p>
                    <% end %>
                    <% if event[:classes].any? %>
                      <p>Classes: <%= event[:classes].join(", ") %></p>
                    <% end %>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
