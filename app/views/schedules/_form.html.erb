<%= form_with(model: schedule) do |form| %>
  <% if schedule.errors.any? %>
    <div class="mb-6 rounded-lg border border-red-200 bg-red-50 p-4">
      <h2 class="mb-2 text-lg font-semibold text-red-800">
        <%= pluralize(schedule.errors.count, "error") %> prohibited this schedule from being saved:
      </h2>
      <ul class="list-inside list-disc space-y-1">
        <% schedule.errors.full_messages.each do |message| %>
          <li class="text-red-700"><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <%= form.label :room_id, "Room", class: "mb-1 block text-sm font-medium text-gray-700" %>
      <%= form.collection_select :room_id, @rooms, :id, :name, { prompt: "Select a room" }, class: "w-full rounded-md border border-gray-300 px-3 py-2" %>
    </div>

    <div>
      <%= form.label :unity_id, "Course", class: "mb-1 block text-sm font-medium text-gray-700" %>
      <%= form.collection_select :unity_id, @unities, :id, :name, { prompt: "Select a course" }, class: "w-full rounded-md border border-gray-300 px-3 py-2" %>
    </div>

    <div>
      <%= form.label :day, class: "mb-1 block text-sm font-medium text-gray-700" %>
      <%= form.date_field :day, class: "w-full rounded-md border border-gray-300 px-3 py-2" %>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= form.label :start_time, class: "mb-1 block text-sm font-medium text-gray-700" %>
        <%= form.time_field :start_time, class: "w-full rounded-md border border-gray-300 px-3 py-2" %>
      </div>

      <div>
        <%= form.label :end_time, class: "mb-1 block text-sm font-medium text-gray-700" %>
        <%= form.time_field :end_time, class: "w-full rounded-md border border-gray-300 px-3 py-2" %>
      </div>
    </div>
  </div>

  <div class="mt-6 grid gap-4 md:grid-cols-2">
    <div>
      <%= form.label :collaborator_ids, "Collaborators", class: "mb-1 block text-sm font-medium text-gray-700" %>
      <%= hidden_field_tag "schedule[collaborator_ids][]", "" %>
      <div class="max-h-72 space-y-2 overflow-y-auto rounded-md border border-gray-300 bg-white p-3">
        <% @collaborators.each do |collaborator| %>
          <label class="flex items-center gap-3 rounded-md px-3 py-2 hover:bg-gray-50">
            <%= check_box_tag "schedule[collaborator_ids][]", collaborator.id, schedule.collaborator_ids.include?(collaborator.id), class: "rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>
            <span class="text-sm text-gray-800"><%= collaborator.full_name %></span>
          </label>
        <% end %>
      </div>
    </div>

    <div>
      <%= form.label :school_class_ids, "Classes", class: "mb-1 block text-sm font-medium text-gray-700" %>
      <%= hidden_field_tag "schedule[school_class_ids][]", "" %>
      <div class="max-h-72 space-y-2 overflow-y-auto rounded-md border border-gray-300 bg-white p-3">
        <% @school_classes.each do |school_class| %>
          <label class="flex items-center gap-3 rounded-md px-3 py-2 hover:bg-gray-50">
            <%= check_box_tag "schedule[school_class_ids][]", school_class.id, schedule.school_class_ids.include?(school_class.id), class: "rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>
            <span class="text-sm text-gray-800"><%= school_class.name %></span>
          </label>
        <% end %>
      </div>
    </div>
  </div>

  <div class="mt-6">
    <%= form.submit class: "w-full rounded-md bg-blue-600 px-4 py-2 font-medium text-white hover:bg-blue-700" %>
  </div>
<% end %>
