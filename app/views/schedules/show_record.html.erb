<div class="mx-auto max-w-4xl p-6">
  <% if notice %>
    <p class="mb-6 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-emerald-800"><%= notice %></p>
  <% end %>

  <div class="space-y-6 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
    <div>
      <h1 class="text-3xl font-bold text-gray-900"><%= @schedule.unity.name %></h1>
      <p class="mt-1 text-sm text-gray-500">Scheduled course details</p>
    </div>

    <div class="grid gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-slate-50 px-4 py-3">
        <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Day</p>
        <p class="mt-1 text-sm font-medium text-slate-900"><%= @schedule.day&.strftime("%d.%m.%Y") || "No date" %></p>
      </div>
      <div class="rounded-xl bg-slate-50 px-4 py-3">
        <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Time</p>
        <p class="mt-1 text-sm font-medium text-slate-900"><%= @schedule.start_time&.strftime("%H:%M") || "--:--" %> - <%= @schedule.end_time&.strftime("%H:%M") || "--:--" %></p>
      </div>
      <div class="rounded-xl bg-slate-50 px-4 py-3">
        <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Room</p>
        <p class="mt-1 text-sm font-medium text-slate-900"><%= @schedule.room&.name || "No room" %></p>
      </div>
      <div class="rounded-xl bg-slate-50 px-4 py-3">
        <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Collaborators</p>
        <p class="mt-1 text-sm font-medium text-slate-900"><%= @schedule.collaborators.map(&:full_name).join(", ").presence || "None" %></p>
      </div>
      <div class="rounded-xl bg-slate-50 px-4 py-3 sm:col-span-2">
        <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Classes</p>
        <p class="mt-1 text-sm font-medium text-slate-900"><%= @schedule.school_classes.map(&:name).join(", ").presence || "None" %></p>
      </div>
    </div>

    <div class="flex flex-wrap gap-3 border-t border-gray-200 pt-4">
      <%= link_to "Edit", edit_schedule_path(@schedule), class: "rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700" %>
      <%= link_to "Back to schedules", schedules_path, class: "rounded-lg bg-slate-700 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800" %>
    </div>
  </div>
</div>
