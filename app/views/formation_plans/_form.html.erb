<%= form_with(model: formation_plan) do |form| %>
  <% if formation_plan.errors.any? %>
    <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
      <h2 class="text-lg font-semibold text-red-800 mb-2">
        <%= pluralize(formation_plan.errors.count, "error") %> prohibited this formation plan from being saved:
      </h2>
      <ul class="list-disc list-inside space-y-1">
        <% formation_plan.errors.full_messages.each do |message| %>
          <li class="text-red-700"><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-4">
    <div>
      <%= form.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :name, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
    </div>

    <div>
      <%= form.label :formation_module_ids, "Modules", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= hidden_field_tag "formation_plan[formation_module_ids][]", "" %>
      <div class="rounded-md border border-gray-300 p-3 bg-white max-h-72 overflow-y-auto space-y-2">
        <% FormationModule.order(:name).each do |module_| %>
          <label class="flex items-center gap-3 px-3 py-2 rounded-md hover:bg-gray-50">
            <%= check_box_tag "formation_plan[formation_module_ids][]", module_.id, formation_plan.formation_module_ids.include?(module_.id), class: "rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>
            <span class="text-sm text-gray-800"><%= module_.name %></span>
          </label>
        <% end %>
      </div>
    </div>

    <div>
      <%= form.submit class: "w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-md" %>
    </div>
  </div>
<% end %>
