<div class="p-6">
  <% if notice %>
  <p class="mb-4 p-4 bg-green-100 text-green-700 rounded"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold">Collaborators</h1>
    <% if current_person.is_a?(Dean) %>
    <%= link_to "New collaborator", new_collaborator_path, class: "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700" %>
    <% end %>
  </div>

  <div class="overflow-x-auto shadow-md rounded-lg">
    <table class="w-full border-collapse">
      <thead class="bg-gray-100 border-b">
        <tr>
          <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">First name</th>
          <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Last name</th>
          <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Email</th>
          <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @collaborators.each do |collaborator| %>
        <tr class="border-b hover:bg-gray-50">
          <td class="px-6 py-4 text-sm text-gray-900"><%= collaborator.firstname %></td>
          <td class="px-6 py-4 text-sm text-gray-900"><%= collaborator.lastname %></td>
          <td class="px-6 py-4 text-sm text-gray-900"><%= collaborator.email %></td>
          <td class="px-6 py-4 text-sm space-x-2">
            <%= link_to "Show", collaborator_path(collaborator), class: "text-blue-600 hover:text-blue-800" %>
            <% if current_person.is_a?(Dean) %>
            <%= link_to "Edit", edit_collaborator_path(collaborator), class: "text-yellow-600 hover:text-yellow-800" %>
            <%= link_to "Destroy", collaborator_path(collaborator), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-red-600 hover:text-red-800" %>
            <% end %>
          </td>
        </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
