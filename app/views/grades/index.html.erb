<div class="container mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold mb-6">
    <%= link_to @student.full_name, student_path(@student), class: "text-blue-600 hover:text-blue-700 transition" %> Grades
  </h1>

  <% if current_person.is_a?(Collaborator) %>
    <%= link_to "Add Grade", new_student_grade_path(@student), class: "inline-block px-4 py-2 mb-6 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition" %>
  <% end %>

  <% if @grades_by_module.any? %>
    <div class="space-y-6">
      <% @grades_by_module.each do |formation_module, module_grades| %>
        <% module_name = formation_module&.name || "Unassigned Module" %>
        <% average = module_average(module_grades) %>
        <% sorted_grades = module_grades.sort_by { |grade| grade.unity.name } %>
        <div class="rounded-lg border border-gray-200 shadow-sm">
              <div class="bg-gray-50 px-6 py-4 flex flex-wrap items-center justify-between gap-4">
                <div>
                  <p class="text-lg font-semibold text-gray-900"><%= module_name %></p>
                  <p class="text-sm text-gray-500">
                    Average grade
                    <span class="<%= grade_color_class(average) %>"><%= number_with_precision(average || 0, precision: 2, strip_insignificant_zeros: true) %></span>
                  </p>
                </div>
            <p class="text-sm font-medium text-gray-700">
              <%= pluralize(sorted_grades.size, "grade") %>
            </p>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead class="bg-gray-100 border-b border-gray-200">
                <tr>
                  <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Unity</th>
                  <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Grade</th>
                  <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Date</th>
                  <% if current_person.is_a?(Collaborator) %>
                    <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Actions</th>
                  <% end %>
                </tr>
              </thead>
              <tbody>
                <% sorted_grades.each do |grade| %>
                  <tr class="border-b border-gray-200 hover:bg-gray-50 transition">
                    <td class="px-6 py-4 text-sm text-gray-900"><%= grade.unity.name %></td>
                    <td class="px-6 py-4 text-sm font-semibold <%= grade_color_class(grade.value) %>"><%= grade.value %></td>
                    <td class="px-6 py-4 text-sm text-gray-900"><%= grade.created_at.strftime("%d/%m/%Y") %></td>
                    <% if current_person.is_a?(Collaborator) %>
                      <td class="px-6 py-4 text-sm space-x-2">
                        <%= link_to "Edit", edit_student_grade_path(@student, grade), class: "inline-block px-3 py-1 bg-yellow-500 text-white font-semibold rounded hover:bg-yellow-600 transition" %>
                        <%= link_to "Delete", student_grade_path(@student, grade), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "inline-block px-3 py-1 bg-red-600 text-white font-semibold rounded hover:bg-red-700 transition" %>
                      </td>
                    <% end %>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-gray-600 text-center py-8">No grades found.</p>
  <% end %>
</div>
