<div class="p-6">
  <% if notice %>
  <p class="mb-4 p-4 bg-green-50 text-green-700 border border-green-200 rounded"><%= notice %></p>
  <% end %>

  <h1 class="text-3xl font-bold mb-6"><%= title %></h1>

  <div class="space-y-4 mb-8">
    <p>
      <strong class="text-gray-700">First name:</strong>
      <span class="text-gray-600"><%= person.firstname %></span>
    </p>

    <p>
      <strong class="text-gray-700">Last name:</strong>
      <span class="text-gray-600"><%= person.lastname %></span>
    </p>

    <p>
      <strong class="text-gray-700">Email:</strong>
      <span class="text-gray-600"><%= person.email %></span>
    </p>

    <% if can_view_sensitive_person_data? %>
    <p>
      <strong class="text-gray-700">AVS number:</strong>
      <span class="text-gray-600"><%= person.avs_number %></span>
    </p>

    <p>
      <strong class="text-gray-700">Phone number:</strong>
      <span class="text-gray-600"><%= person.phone_number %></span>
    </p>

    <p>
      <strong class="text-gray-700">Street:</strong>
      <span class="text-gray-600"><%= [ person.street, person.street_number ].compact.join(" ") %></span>
    </p>

    <p>
      <strong class="text-gray-700">Postal code:</strong>
      <span class="text-gray-600"><%= person.postal_code %></span>
    </p>

    <p>
      <strong class="text-gray-700">City:</strong>
      <span class="text-gray-600"><%= person.city %></span>
    </p>
    <% end %>

    <p>
      <strong class="text-gray-700">Birthdate:</strong>
      <span class="text-gray-600"><%= person.birthdate %></span>
    </p>

    <p>
      <strong class="text-gray-700">Age:</strong>
      <span class="text-gray-600"><%= person.age %></span>
    </p>

    <% if block_given? %>
    <%= yield(person) %>
    <% end %>
  </div>

  <div class="flex gap-4 mb-4">
    <% if current_person.is_a?(Dean) %>
    <%= link_to "Edit", edit_polymorphic_path(person), class: "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700" %>
    <% end %>
    <%= link_to back_label, back_path, class: "px-4 py-2 bg-gray-600 text-white rounded hover:bg-gray-700" %>
  </div>

  <% if current_person.is_a?(Dean) %>
  <div>
    <%= link_to "Destroy", person, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700" %>
  </div>
  <% end %>
</div>
