<div class="mx-auto max-w-5xl p-6">
  <% if notice %>
  <p class="mb-6 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-emerald-800"><%= notice %></p>
  <% end %>

  <section class="overflow-hidden rounded-3xl border border-gray-200 bg-white shadow-sm">
    <div class="relative bg-gradient-to-r from-slate-100 via-blue-50 to-slate-100 px-6 pb-8 pt-10 sm:px-10">
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-slate-300 to-transparent"></div>
      <div class="flex flex-col items-center gap-5 sm:flex-row sm:items-end">
        <div class="flex h-28 w-28 shrink-0 items-center justify-center overflow-hidden rounded-full border-4 border-white bg-gray-100 text-gray-400 shadow-md">
          <% if person.profile_picture.attached? %>
            <%= image_tag person.profile_picture, class: "h-full w-full object-cover" %>
          <% else %>
            <svg class="h-12 w-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 21v-2a5 5 0 0 0-10 0v2M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8z"></path>
            </svg>
          <% end %>
        </div>

        <div class="text-center sm:text-left">
          <p class="text-sm font-semibold uppercase tracking-[0.14em] text-slate-500"><%= title %> profile</p>
          <h1 class="mt-1 text-3xl font-bold text-slate-900"><%= [person.firstname, person.lastname].compact.join(" ") %></h1>
          <p class="mt-2 text-sm text-slate-600"><%= person.email %></p>
        </div>
      </div>
    </div>

    <div class="space-y-8 px-6 py-8 sm:px-10">
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-xl bg-slate-50 px-4 py-3">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">First name</p>
          <p class="mt-1 text-sm font-medium text-slate-900"><%= person.firstname %></p>
        </div>
        <div class="rounded-xl bg-slate-50 px-4 py-3">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Last name</p>
          <p class="mt-1 text-sm font-medium text-slate-900"><%= person.lastname %></p>
        </div>
        <div class="rounded-xl bg-slate-50 px-4 py-3">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Email</p>
          <p class="mt-1 text-sm font-medium text-slate-900 break-all"><%= person.email %></p>
        </div>
        <div class="rounded-xl bg-slate-50 px-4 py-3">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Birthdate</p>
          <p class="mt-1 text-sm font-medium text-slate-900"><%= person.birthdate %></p>
        </div>
        <div class="rounded-xl bg-slate-50 px-4 py-3">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Age</p>
          <p class="mt-1 text-sm font-medium text-slate-900"><%= person.age %></p>
        </div>

        <% if can_view_sensitive_person_data? %>
        <div class="rounded-xl bg-slate-50 px-4 py-3">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">AVS number</p>
          <p class="mt-1 text-sm font-medium text-slate-900"><%= person.avs_number %></p>
        </div>
        <div class="rounded-xl bg-slate-50 px-4 py-3">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Phone number</p>
          <p class="mt-1 text-sm font-medium text-slate-900"><%= person.phone_number %></p>
        </div>
        <div class="rounded-xl bg-slate-50 px-4 py-3">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Street</p>
          <p class="mt-1 text-sm font-medium text-slate-900"><%= [ person.street, person.street_number ].compact.join(" ") %></p>
        </div>
        <div class="rounded-xl bg-slate-50 px-4 py-3">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Postal code</p>
          <p class="mt-1 text-sm font-medium text-slate-900"><%= person.postal_code %></p>
        </div>
        <div class="rounded-xl bg-slate-50 px-4 py-3">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">City</p>
          <p class="mt-1 text-sm font-medium text-slate-900"><%= person.city %></p>
        </div>
        <% end %>
      </div>

      <% if block_given? %>
      <div class="grid gap-3 sm:grid-cols-2 [&>p]:rounded-xl [&>p]:bg-slate-50 [&>p]:px-4 [&>p]:py-3 [&>p>strong]:block [&>p>strong]:text-xs [&>p>strong]:font-semibold [&>p>strong]:uppercase [&>p>strong]:tracking-wide [&>p>strong]:text-slate-500 [&>p>span]:mt-1 [&>p>span]:block [&>p>span]:text-sm [&>p>span]:font-medium [&>p>span]:text-slate-900">
        <%= yield(person) %>
      </div>
      <% end %>

      <div class="flex flex-wrap items-center justify-between gap-3 border-t border-slate-200 pt-6">
        <div class="flex flex-wrap gap-3">
          <% if current_person.is_a?(Dean) %>
          <%= link_to "Edit", edit_polymorphic_path(person), class: "rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-blue-700" %>
          <% end %>
          <%= link_to back_label, back_path, class: "rounded-lg bg-slate-700 px-4 py-2 text-sm font-medium text-white transition hover:bg-slate-800" %>
        </div>

        <% if current_person.is_a?(Dean) %>
        <%= link_to "Destroy", person, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-red-700" %>
        <% end %>
      </div>
    </div>
  </section>
</div>
