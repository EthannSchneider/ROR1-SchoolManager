<div class="p-6">
  <h1 class="text-3xl font-bold mb-6">Dean</h1>

  <div class="space-y-3 mb-6">
    <p><strong>First name:</strong> <%= @dean.firstname %></p>
    <p><strong>Last name:</strong> <%= @dean.lastname %></p>
    <p><strong>Email:</strong> <%= @dean.email %></p>
    <p><strong>AVS number:</strong> <%= @dean.avs_number %></p>
    <p><strong>Phone number:</strong> <%= @dean.phone_number %></p>
    <p><strong>Street:</strong> <%= [ @dean.street, @dean.street_number ].compact.join(" ") %></p>
    <p><strong>Postal code:</strong> <%= @dean.postal_code %></p>
    <p><strong>City:</strong> <%= @dean.city %></p>
    <p><strong>Birthdate:</strong> <%= @dean.birthdate %></p>
    <p><strong>Age:</strong> <%= @dean.age %></p>
  </div>

  <div class="flex gap-3">
    <%= link_to "Back", deans_path, class: "px-4 py-2 bg-gray-600 text-white rounded hover:bg-gray-700" %>
    <% if current_person.is_a?(Dean) %>
    <%= link_to "Edit", edit_dean_path(@dean), class: "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700" %>
    <%= link_to "Destroy", dean_path(@dean), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700" %>
    <% end %>
  </div>
</div>
