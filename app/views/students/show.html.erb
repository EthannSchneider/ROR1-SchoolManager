<%= render "shared/person_show",
  person: @student,
  title: "Student",
  back_path: students_path,
  back_label: "Back to students" do |student| %>
<%= person_detail_card("Class", student.school_class&.name) %>
<%= person_detail_card("Admission date", student.admission_date) %>
<%= person_detail_card("End date", student.end_date) %>
<% end %>