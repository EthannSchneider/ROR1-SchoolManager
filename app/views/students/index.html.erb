<%= render "shared/person_index",
  records: @students,
  title: "Students",
  new_path: new_student_path,
  new_label: "New student",
  extra_fields: [
    { label: "Class", value: ->(student) { student.school_class&.name || "-" } },
    { label: "Admission date", value: ->(student) { student.admission_date } },
    { label: "End date", value: ->(student) { student.end_date } }
  ],
  footer_partial: "shared/students_index_footer",
  footer_locals: { students: @students, per_page: (params[:per_page] || 10) } %>
