<div class="p-6">
  <% if notice %>
    <p class="mb-4 rounded bg-green-100 p-4 text-green-700"><%= notice %></p>
  <% end %>

  <div class="mb-6">
    <%= link_to "← Back to rooms", rooms_path, class: "text-blue-600 hover:text-blue-800" %>
  </div>

  <div class="rounded-lg bg-white p-6 shadow-md">
    <div class="mb-6 flex items-start justify-between">
      <h1 class="text-3xl font-bold text-gray-900"><%= @room.name %></h1>
      <% if current_person.is_a?(Dean) %>
        <div class="flex gap-2">
          <%= link_to "Edit", edit_room_path(@room), class: "rounded bg-yellow-600 px-4 py-2 text-white hover:bg-yellow-700" %>
          <%= link_to "Destroy", room_path(@room), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "rounded bg-red-600 px-4 py-2 text-white hover:bg-red-700" %>
        </div>
      <% end %>
    </div>

    <div>
      <p class="text-sm font-medium uppercase tracking-wide text-gray-500">Room name</p>
      <p class="mt-2 text-lg text-gray-900"><%= @room.name %></p>
    </div>

    <div class="mt-8 border-t border-gray-200 pt-6">
      <div class="flex flex-wrap gap-3">
        <%= link_to "View room schedule", schedule_room_path(@room), class: "rounded bg-blue-600 px-4 py-2 text-white hover:bg-blue-700" %>
        <% if current_person.is_a?(Dean) %>
          <%= link_to "Add schedule", new_schedule_path(room_id: @room.id), class: "rounded bg-slate-700 px-4 py-2 text-white hover:bg-slate-800" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
